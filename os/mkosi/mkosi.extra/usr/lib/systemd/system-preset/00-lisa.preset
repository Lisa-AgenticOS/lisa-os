# Authoritative service enablement for Lisa images (PLAN §3, §6).
#
# mkosi applies systemd presets during image finalization, and Arch's
# stock presets DISABLE most services — which silently overrode the
# postinst `systemctl enable` (NetworkManager shipped disabled → no
# Wi-Fi on the field iMac until started by hand). A preset file sorts
# first (00-) and wins, so these stay enabled regardless of the postinst
# or stock presets. Units absent on a given image flavor (e.g. gdm on the
# minimal CI boot-check) are simply skipped.

enable lisa-inferenced.service
enable lisa-model-store.service
enable lisa-boot-report.service
enable gdm.service
# Boot-splash lifecycle: keep the units that quit Plymouth and hand the
# framebuffer to GDM (a stock `disable *` preset would otherwise break the
# handoff, leaving a black screen until Plymouth times out). plymouth-start
# itself has no [Install]; it is wired into sysinit.target by a
# mkosi.extra symlink instead.
enable plymouth-quit.service
enable plymouth-quit-wait.service
enable plymouth-read-write.service
enable NetworkManager.service
enable iwd.service
enable systemd-resolved.service
enable bluetooth.service
enable sshd.service
enable systemd-sysupdate.timer
