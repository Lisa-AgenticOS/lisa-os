<?xml version="1.0" encoding="UTF-8"?>
<!-- Keybinding schema for the assistant overlay (PLAN §5.7.1: summon
     with Super+Shift+Space — Super+Space alone is the Spotlight-style
     search, §5.7.2). Compile with glib-compile-schemas at install;
     GNOME's input-source switcher also defaults to Super+Space — the
     image build (Track I) and layer install (Track L) remap that to
     Ctrl+Super+Space so both Lisa surfaces win. -->
<schemalist>
  <schema id="org.gnome.shell.extensions.lisa-overlay"
          path="/org/gnome/shell/extensions/lisa-overlay/">
    <key name="toggle-overlay" type="as">
      <default><![CDATA[['<Shift><Super>space']]]></default>
      <summary>Summon or dismiss the assistant overlay</summary>
    </key>
    <key name="open-assistant" type="as">
      <default><![CDATA[['<Super>c']]]></default>
      <summary>Open the Lisa Assistant chat window</summary>
      <description>Opens (or focuses) the persistent chat window. Super+A is
      GNOME's app grid, so this defaults to Super+C — rebindable in
      Settings.</description>
    </key>
  </schema>
</schemalist>
